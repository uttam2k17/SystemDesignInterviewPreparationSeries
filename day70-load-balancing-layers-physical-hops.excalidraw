    {
      "id": "sidecar-tx",
      "type": "text",
      "x": 56,
      "y": 352,
      "width": 508,
      "height": 96,
      "text": "THE SIDECAR TRICK (most common junior mistake)\nGateway sends to Pod IP → iptables intercepts → Sidecar (Envoy) → localhost loopback → App\nSame host · Same network namespace · 0 extra physical hops · tiny CPU cost only",
      "fontSize": 13,
      "fontFamily": 1,
      "strokeColor": "#a6e3a1",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
