    {
      "id": "footer-tx",
      "type": "text",
      "x": 60, "y": 3502,
      "width": 400, "height": 20,
      "text": "\"A developer makes the code work. An architect makes the system last.\"",
      "fontSize": 11, "fontFamily": 1,
      "strokeColor": "#585b70", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
