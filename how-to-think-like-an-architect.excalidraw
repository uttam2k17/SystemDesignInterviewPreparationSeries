    },
    {
      "id": "b8-title",
      "type": "text",
      "x": 80, "y": 2566,
      "width": 360, "height": 36,
      "text": "Observability is not optional — it is the design.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#a6e3a1", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1083, "version": 1, "versionNonce": 1083,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Observability is not optional — it is the design.", "angle": 0, "groupIds": []
    },
    {
      "id": "b8-body",
      "type": "text",
      "x": 80, "y": 2616,
      "width": 360, "height": 148,
      "text": "A system you cannot observe\nis a system you cannot operate.\n\nIf you can't answer \"is this healthy?\"\nwithin 60 seconds of an incident —\nyour system is not done,\nregardless of what features shipped.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1084, "version": 1, "versionNonce": 1084,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A system you cannot observe\nis a system you cannot operate.\n\nIf you can't answer \"is this healthy?\"\nwithin 60 seconds of an incident —\nyour system is not done,\nregardless of what features shipped.", "angle": 0, "groupIds": []
    },

    {
