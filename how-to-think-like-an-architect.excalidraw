    {
      "id": "b9-div",
      "type": "line",
      "x": 100, "y": 2894,
      "width": 320, "height": 0,
      "strokeColor": "#7a7a2a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 40,
      "seed": 1092, "version": 1, "versionNonce": 1092,
      "isDeleted": false, "boundElements": null, "updated": 1,
