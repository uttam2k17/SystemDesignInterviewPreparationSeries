    {
      "id": "b2-title",
      "type": "text",
      "x": 80, "y": 526,
      "width": 360, "height": 36,
      "text": "Every technical decision is a business decision.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#a6e3a1", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1023, "version": 1, "versionNonce": 1023,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Every technical decision is a business decision.", "angle": 0, "groupIds": []
    },
    {
      "id": "b2-body",
      "type": "text",
      "x": 80, "y": 576,
      "width": 360, "height": 148,
      "text": "Choosing Kafka over RabbitMQ is a cost,\nhiring pipeline, and operational complexity choice.\n\nIf you can't explain your architecture decision\nto a non-engineer in two sentences,\nyou probably haven't thought it through.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1024, "version": 1, "versionNonce": 1024,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Choosing Kafka over RabbitMQ is a cost,\nhiring pipeline, and operational complexity choice.\n\nIf you can't explain your architecture decision\nto a non-engineer in two sentences,\nyou probably haven't thought it through.", "angle": 0, "groupIds": []
    },

