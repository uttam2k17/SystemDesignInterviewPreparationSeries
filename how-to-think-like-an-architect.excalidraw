    },
    {
      "id": "b10-title",
      "type": "text",
      "x": 80, "y": 3246,
      "width": 360, "height": 36,
      "text": "Trade-offs are the job. There are no free choices.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f2cdcd", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1103, "version": 1, "versionNonce": 1103,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Trade-offs are the job. There are no free choices.", "angle": 0, "groupIds": []
    },
    {
      "id": "b10-body",
      "type": "text",
      "x": 80, "y": 3296,
      "width": 360, "height": 148,
      "text": "Speed vs consistency.\nSimplicity vs flexibility.\nCost vs resilience.\n\nEvery choice trades something away.\n\nThe architect's job is not to make\nthe right choice — it's to document\nwhat was traded and why.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1104, "version": 1, "versionNonce": 1104,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Speed vs consistency.\nSimplicity vs flexibility.\nCost vs resilience.\n\nEvery choice trades something away.\n\nThe architect's job is not to make\nthe right choice — it's to document\nwhat was traded and why.", "angle": 0, "groupIds": []
    },

