      "text": "09",
      "fontSize": 34, "fontFamily": 1,
      "strokeColor": "#7a7a2a", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
