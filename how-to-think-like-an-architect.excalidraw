    {
      "id": "b5-title",
      "type": "text",
      "x": 80, "y": 1546,
      "width": 360, "height": 36,
      "text": "Consistency is a spectrum, not a switch.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f9e2af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1053, "version": 1, "versionNonce": 1053,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Consistency is a spectrum, not a switch.", "angle": 0, "groupIds": []
    },
    {
      "id": "b5-body",
      "type": "text",
      "x": 80, "y": 1596,
      "width": 360, "height": 148,
      "text": "Developers think: consistent or not consistent.\n\nArchitects think in degrees — strong, eventual,\ncausal, read-your-writes, monotonic reads.\n\nChoosing the right consistency level\nis choosing the right business contract.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1054, "version": 1, "versionNonce": 1054,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Developers think: consistent or not consistent.\n\nArchitects think in degrees — strong, eventual,\ncausal, read-your-writes, monotonic reads.\n\nChoosing the right consistency level\nis choosing the right business contract.", "angle": 0, "groupIds": []
    },

