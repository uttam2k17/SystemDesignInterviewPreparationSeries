    },
    {
      "id": "b9-title",
      "type": "text",
      "x": 80, "y": 2906,
      "width": 360, "height": 36,
      "text": "The best architecture is one your team can evolve.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#f9e2af", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1093, "version": 1, "versionNonce": 1093,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "The best architecture is one your team can evolve.", "angle": 0, "groupIds": []
    },
    {
      "id": "b9-body",
      "type": "text",
      "x": 80, "y": 2956,
      "width": 360, "height": 148,
      "text": "A perfect design that no one on your team\nunderstands is not an asset — it's a liability.\n\nComplexity is a debt that arrives with interest.\n\nThe right architecture is the simplest one\nthat lets your team move fast next quarter.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1094, "version": 1, "versionNonce": 1094,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "A perfect design that no one on your team\nunderstands is not an asset — it's a liability.\n\nComplexity is a debt that arrives with interest.\n\nThe right architecture is the simplest one\nthat lets your team move fast next quarter.", "angle": 0, "groupIds": []
    },

    {
      "id": "b10-rect",
      "type": "rectangle",
      "x": 60, "y": 3160,
      "width": 400, "height": 300,
      "strokeColor": "#8a3a5a", "backgroundColor": "#200a12",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 0, "opacity": 100,
      "seed": 1100, "version": 1, "versionNonce": 1100,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "angle": 0, "groupIds": [],
      "roundness": { "type": 3 }
    },
