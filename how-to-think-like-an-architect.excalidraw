    {
      "id": "b6-title",
      "type": "text",
      "x": 80, "y": 1886,
      "width": 360, "height": 36,
      "text": "The boring choice is usually the right choice.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#94e2d5", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1063, "version": 1, "versionNonce": 1063,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "The boring choice is usually the right choice.", "angle": 0, "groupIds": []
    },
    {
      "id": "b6-body",
      "type": "text",
      "x": 80, "y": 1936,
      "width": 360, "height": 148,
      "text": "Juniors want the shiniest new tech.\n\nArchitects want technology their team can\noperate confidently at 3 AM when it breaks.\n\nBoring = battle-tested = fewer surprises\nin production when it matters most.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1064, "version": 1, "versionNonce": 1064,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "Juniors want the shiniest new tech.\n\nArchitects want technology their team can\noperate confidently at 3 AM when it breaks.\n\nBoring = battle-tested = fewer surprises\nin production when it matters most.", "angle": 0, "groupIds": []
    },

