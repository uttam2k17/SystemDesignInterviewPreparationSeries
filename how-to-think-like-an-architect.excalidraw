    {
      "id": "b4-title",
      "type": "text",
      "x": 80, "y": 1206,
      "width": 360, "height": 36,
      "text": "More is not better — more is the problem.",
      "fontSize": 14, "fontFamily": 1,
      "strokeColor": "#cba6f7", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1043, "version": 1, "versionNonce": 1043,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "More is not better — more is the problem.", "angle": 0, "groupIds": []
    },
    {
      "id": "b4-body",
      "type": "text",
      "x": 80, "y": 1256,
      "width": 360, "height": 148,
      "text": "100 DB connections per pod doesn't mean 10×\nthroughput — it means 10× context switching.\n\nMore microservices don't mean more flexibility.\nThey mean more failure points, more latency,\nmore operational surface area.",
      "fontSize": 12, "fontFamily": 1,
      "strokeColor": "#a6adc8", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100,
      "textAlign": "center", "verticalAlign": "top",
      "seed": 1044, "version": 1, "versionNonce": 1044,
      "isDeleted": false, "boundElements": null, "updated": 1,
      "link": null, "locked": false, "containerId": null,
      "originalText": "100 DB connections per pod doesn't mean 10×\nthroughput — it means 10× context switching.\n\nMore microservices don't mean more flexibility.\nThey mean more failure points, more latency,\nmore operational surface area.", "angle": 0, "groupIds": []
    },

