    {
      "id": "insight-text",
      "type": "text",
      "x": 50,
      "y": 965,
      "width": 1380,
      "height": 60,
      "text": "💡 The Rendezvous Hashing guarantee:  Add or remove a node → only the keys touching that node are reassigned.  No avalanche, no ring, no virtual nodes.\nJust  argmax( hash(key, node) )  computed independently by every client — O(N) per lookup, perfect for clusters up to a few hundred nodes.",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#51cf66",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
